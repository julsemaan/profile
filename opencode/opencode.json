{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "opencode/gpt-5.3-codex",
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "medium"
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high"
    }
  },
  "instructions": [],
  "share": "disabled",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
      "~/src/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.opencode/**": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "doom_loop": "ask",
    "skill": "allow",
    "bash": {
      "*": "allow"
    }
  },
  "command": {
    "gotest": {
      "template": "Run `go test ./...` and fix any test failures.",
      "description": "Run Go tests",
      "agent": "build"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false
    }
  }
}
