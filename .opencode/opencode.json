{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-balanced"
    },
    "handle-pr-review-feedback": {
      "mode": "subagent",
      "model": "openai/gpt-high"
    },
    "brainstorm-designer": {
      "mode": "primary",
      "model": "openai/gpt-xhigh"
    },
    "bitbucket-pr-review": {
      "mode": "subagent",
      "model": "openai/gpt-high"
    },
    "github-pr-review": {
      "mode": "subagent",
      "model": "openai/gpt-high"
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-high"
    },
    "update-bitbucket-pipe-pr": {
      "mode": "subagent",
      "model": "openai/gpt-balanced"
    }
  },
  "instructions": [],
  "share": "disabled",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
      "~/src/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.opencode/**": "allow",
      "~/go/**": "allow",
      "/opencode/**": "allow",
      "/tmp/**": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "doom_loop": "ask",
    "skill": "allow",
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny"
    }
  },
  "command": {
    "doit": {
      "template": "Implement the plan",
      "description": "Implement the current plan",
      "agent": "build"
    },
    "review-n-post": {
      "template": "Review $ARGUMENTS using the github-pr-review agent or bitbucket-pr-review agent depending on the repository.",
      "description": "Perform a PR review and post the review comments",
      "agent": "build"
    },
    "handle-review": {
      "template": "Handle the following PR review feedback: $ARGUMENTS using the handle-pr-review-feedback agent.",
      "description": "Handle PR review feedback using the handle-pr-review-feedback agent",
      "agent": "build"
    },
    "extract-feedback": {
      "template": "Extract the feedback that is not yet addressed from $ARGUMENTS and put it in julsemaan-tmp/feedback.md",
      "description": "Extract feedback from pull requests that is not yet addressed.",
      "agent": "build"
    },
    "plan": {
      "template": "$ARGUMENTS",
      "description": "Send prompt to plan agent",
      "agent": "plan"
    },
    "gotest": {
      "template": "Run `go test ./...` and fix any test failures.",
      "description": "Run Go tests",
      "agent": "build"
    },
    "update-bitbucket-pipe-pr": {
      "template": "$ARGUMENTS",
      "description": "Create PRs to update a pipe image reference across Bitbucket repos. Example: update-bitbucket-pipe-pr repos: workspace/repo1, workspace/repo2 image: docker://...",
      "agent": "update-bitbucket-pipe-pr"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-balanced": {
          "id": "gpt-5.4",
          "name": "GPT Balanced",
          "limit": {
            "context": 256000,
            "output": 32768
          }
        },
        "gpt-high": {
          "id": "gpt-5.4",
          "name": "GPT high",
          "options": {
            "reasoningEffort": "high"
          },
          "limit": {
            "context": 256000,
            "output": 32768
          }
        },
        "gpt-xhigh": {
          "id": "gpt-5.4",
          "name": "GPT xhigh",
          "options": {
            "reasoningEffort": "xhigh"
          },
          "limit": {
            "context": 512000,
            "output": 32768
          }
        }
      },
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 16000
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GH_MCP_TOKEN}"
      }
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false
    },
    "bitbucket": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Basic {env:BB_MCP_TOKEN}"
      }
    }
  }
}
