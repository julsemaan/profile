#!/bin/bash

set -o nounset -o pipefail -o errexit

function check_cmd {
  if ! which $1 > /dev/null; then
    echo "Needs $1"
    exit 5
  fi
}

function install_tpm {
  home="$1"
  if ! [ -d $home/.tmux/plugins/tpm ]; then
    mkdir -p $home/.tmux/plugins
    git clone https://github.com/tmux-plugins/tpm $home/.tmux/plugins/tpm
  fi
  chown -R `basename $home`: $home/.tmux
}

function install_nvim {
  if ! [ -d /opt/nvim-linux64 ]; then
    (
      tmp_tarball=$(mktemp)
      trap 'rm -f "$tmp_tarball"' EXIT
      curl -Lo "$tmp_tarball" https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz || exit 5
      rm -rf /opt/nvim-linux64 /opt/nvim-linux-x86_64
      tar -C /opt -xzf "$tmp_tarball" || exit 5
      # To be compatible with the previous path. Should put this in /opt/nvim and update PATH in the rest of the repo
      mv /opt/nvim-linux-x86_64 /opt/nvim-linux64
    )
  fi
}

function install_nvim_profile {
  home="$1"
  if ! [ -d $home/.config/nvim ]; then
    mkdir -p $home/.config
    git clone https://github.com/julsemaan/nvim-profile $home/.config/nvim
  fi

  cd $home/.config/nvim
  git config --global --add safe.directory $home/.config/nvim
  git pull
  cd -
  
  chown `basename $home`: $home/.config
  chown -R `basename $home`: $home/.config/nvim
}

function install_complete_alias {
  if [ -d /etc/bash_completion.d/ ]; then
    echo "Installing complete_alias"
    curl --fail https://raw.githubusercontent.com/cykerway/complete-alias/refs/heads/master/complete_alias > /etc/bash_completion.d/complete_alias 2>/dev/null
  else
    echo "Skipping complete_alias because /etc/bash_completion.d/ doesn't exist"
  fi
}

function is_ubuntu_desktop {
  if ! [ -f /etc/os-release ]; then
    return 1
  fi

  . /etc/os-release
  if [ "${ID:-}" != "ubuntu" ]; then
    return 1
  fi

  [ -f /usr/share/xsessions/ubuntu.desktop ] || [ -f /usr/share/wayland-sessions/ubuntu.desktop ]
}

function install_file {
  src="$1"
  dst="$2"
  user="${3:-}"
  echo "Installing $src in $dst"
  cp -a $src $dst 
  if ! [ -z "$user" ]; then
    chown -R $user: $dst
  fi
}

function sync_file_atomic {
  local src="$1"
  local dst="$2"

  local dst_dir tmp
  dst_dir=$(dirname "$dst")
  mkdir -p "$dst_dir"

  tmp=$(mktemp "$dst.XXXXXXXXXX")
  cp -a "$src" "$tmp"
  mv -f "$tmp" "$dst"
}

function sync_dir_in_place {
  local src_dir="$1"
  local dst_dir="$2"
  local src_names entry base src_entry dst_entry found s_name

  mkdir -p "$dst_dir"

  # Collect source entry basenames
  src_names=()
  while IFS= read -r entry; do
    src_names+=("$entry")
  done < <(ls -A "$src_dir" 2>/dev/null || true)

  # Sync each source entry into dst
  for base in "${src_names[@]}"; do
    src_entry="$src_dir/$base"
    dst_entry="$dst_dir/$base"
    if [ -f "$src_entry" ]; then
      sync_file_atomic "$src_entry" "$dst_entry"
    elif [ -d "$src_entry" ]; then
      sync_dir_in_place "$src_entry" "$dst_entry"
    fi
  done

  # Remove stale entries in dst that are missing from source
  for entry in "$dst_dir"/* "$dst_dir"/.*; do
    [ -e "$entry" ] || continue
    base=$(basename "$entry")
    [ "$base" = "." ] && continue
    [ "$base" = ".." ] && continue

    found=0
    for s_name in "${src_names[@]}"; do
      if [ "$s_name" = "$base" ]; then
        found=1
        break
      fi
    done

    if [ "$found" -eq 0 ]; then
      echo "  Removing stale: $entry"
      rm -fr "$entry"
    fi
  done
}

function sync_pi_settings_preserving_runtime {
  local src="$1"
  local dst="$2"

  local dst_dir tmp
  dst_dir=$(dirname "$dst")
  mkdir -p "$dst_dir"

  if [ ! -f "$dst" ]; then
    echo "  Installing Pi settings: $dst (new)"
    sync_file_atomic "$src" "$dst"
    return
  fi

  echo "  Syncing Pi settings with runtime package preservation: $dst"
  tmp=$(mktemp "$dst.XXXXXXXXXX")

  python3 - "$src" "$dst" "$tmp" <<'PY'
import json
import sys

src, dst, tmp = sys.argv[1:4]

with open(src, encoding='utf-8') as f:
    result = json.load(f)
with open(dst, encoding='utf-8') as f:
    host = json.load(f)

if isinstance(host.get('packages'), list):
    result['packages'] = host['packages']
elif 'packages' in result:
    result.pop('packages', None)

with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(result, f, indent=2)
    f.write('\n')
PY

  mv -f "$tmp" "$dst"
}

function install_pi_global_config {
  local home="$1"
  local user="$2"
  local profile_dir="$3"
  local agent_dir pi_src managed_dirs exact_sync_files f d

  agent_dir="$home/.pi/agent"
  pi_src="$profile_dir/.pi"

  mkdir -p "$agent_dir"

  exact_sync_files="mcp.json models.json TODO.md web-search.json"
  managed_dirs="extensions prompts agents modes skills"

  if [ -f "$pi_src/settings.json" ]; then
    sync_pi_settings_preserving_runtime "$pi_src/settings.json" "$agent_dir/settings.json"
  fi

  # Sync install-managed files atomically (no delete-before-copy window)
  for f in $exact_sync_files; do
    if [ -f "$pi_src/$f" ]; then
      sync_file_atomic "$pi_src/$f" "$agent_dir/$f"
    fi
  done

  # Sync managed dirs in-place (no whole-tree rm -fr)
  for d in $managed_dirs; do
    if [ -d "$pi_src/$d" ]; then
      sync_dir_in_place "$pi_src/$d" "$agent_dir/$d"
    fi
  done

  chown -R "$user": "$home/.pi"
}

function trigger_bashrc_reload_for_user {
  local home="$1"
  local user="$2"
  local trigger_file token

  trigger_file="$home/.bashrc-reload-trigger"
  token="$(date +%s):$$:$RANDOM"

  printf '%s\n' "$token" > "$trigger_file"
  chown "$user": "$trigger_file"
}

check_cmd git
check_cmd make
check_cmd gawk

# One-time git config (moved from shell startup)
git config --global credential.helper cache

LOCAL_INSTALL=${LOCAL_INSTALL:-}
if [ -z "$LOCAL_INSTALL" ]; then
  d=$(mktemp -d)

  function finish {
    rm -fr $d
  }

  trap finish EXIT

  git clone https://github.com/julsemaan/profile $d
else
  d=`pwd`
fi

install_complete_alias

install_file $d/profile/.bashrc_append /usr/local/etc/.bashrc_append

# Deploy bashrc fragments
rm -fr /usr/local/etc/bashrc.d
install_file $d/profile/bashrc.d/ /usr/local/etc/bashrc.d

install_file $d/profile/.inputrc /usr/local/etc/.inputrc
install_file $d/profile/.tmux.conf /usr/local/etc/.tmux.conf
install_file $d/profile/.vimrc /usr/local/etc/.vimrc
install_file $d/profile/.gitignore /usr/local/etc/.gitignore
install_file $d/profile/.blerc /usr/local/etc/.blerc

install_file $d/profile/tmux-equalize-row.sh /usr/local/etc/tmux-equalize-row.sh
chmod +x /usr/local/etc/tmux-equalize-row.sh

install_file $d/profile/codex-unleashed-safely.sh /usr/local/bin/codex-unleashed-safely
chmod +x /usr/local/bin/codex-unleashed-safely

install_file $d/profile/opencode-unleashed-safely.sh /usr/local/bin/opencode-unleashed-safely
chmod +x /usr/local/bin/opencode-unleashed-safely

install_file $d/profile/pi-unleashed-safely.sh /usr/local/bin/pi-unleashed-safely
chmod +x /usr/local/bin/pi-unleashed-safely

install_file $d/profile/gwt /usr/local/bin/gwt
chmod +x /usr/local/bin/gwt

if is_ubuntu_desktop; then
  install_file $d/utils/90-usb-wakeup.rules /etc/udev/rules.d/90-usb-wakeup.rules
  chown root:root /etc/udev/rules.d/90-usb-wakeup.rules
else
  echo "Skipping USB wakeup udev rule because host is not Ubuntu Desktop"
fi

mkdir -p /usr/local/etc/opencode
rm -fr /usr/local/etc/opencode/*
install_file $d/.opencode/. /usr/local/etc/opencode

rm -fr /usr/local/etc/tmuxifiers
install_file $d/tmuxifiers/ /usr/local/etc/tmuxifiers

install_nvim

if ! [ -f /etc/cron.d/jprofile ] || [ $(md5sum /etc/cron.d/jprofile $d/cron | awk '{print $1}' | uniq | wc -l) -ne 1 ]; then
  if [ -d /etc/cron.d ]; then
    install_file $d/cron /etc/cron.d/jprofile
  else
    echo "Skipping cron installation because /etc/cron.d doesn't exist"
  fi
fi

if ! [ -f /etc/cron.daily/jprofile ] || [ $(md5sum /etc/cron.daily/jprofile $d/cron.daily | awk '{print $1}' | uniq | wc -l) -ne 1 ]; then
  if [ -d /etc/cron.daily ]; then
    install_file $d/cron.daily /etc/cron.daily/jprofile
    chmod +x /etc/cron.daily/jprofile
  else
    echo "Skipping cron.daily installation because /etc/cron.daily doesn't exist"
  fi
fi

VIMRC=""
if [ -f /etc/vimrc ]; then
	VIMRC="/etc/vimrc"
elif [ -f /etc/vim/vimrc ]; then
	VIMRC="/etc/vim/vimrc"
fi

if ! [ -z "$VIMRC" ]; then
  if ! grep 'source /usr/local/etc/.vimrc' $VIMRC > /dev/null 2>&1 ; then
      echo "Installing the sourcing of vimrc in vimrc"
      echo 'source /usr/local/etc/.vimrc' >> $VIMRC
      echo "" >> $VIMRC
  fi
fi

git config --system core.excludesfile /usr/local/etc/.gitignore

homes=(/home/* /root /Users/*)
for home in "${homes[@]}"; do 
  if [ $home == "/home/*" ]; then
    continue
  fi

  if (which dscl > /dev/null 2>&1 && dscl . list /Users | grep -v '^_' | grep `basename $home` >/dev/null) || grep ^`basename $home`: /etc/passwd >/dev/null; then
    if [ -d "$home" ]; then
      install_file /usr/local/etc/.tmux.conf $home/.tmux.conf `basename $home`
      install_file /usr/local/etc/.inputrc $home/.inputrc `basename $home`
      install_file /usr/local/etc/.blerc $home/.blerc `basename $home`

      mkdir -p $home/.config/ghostty $home/.config/kinto $home/.config/direnv $home/.config/herdr
      chown `basename $home`: $home/.config/ghostty $home/.config/kinto $home/.config/direnv $home/.config/herdr
      install_file $d/utils/config.ghostty $home/.config/ghostty/config `basename $home`
      install_file $d/utils/bell.wav $home/.config/ghostty/bell.wav `basename $home`
      install_file $d/utils/kinto.py $home/.config/kinto/kinto.py `basename $home`
      install_file $d/profile/direnv-config.toml $home/.config/direnv/config.toml `basename $home`
      install_file $d/profile/herdr-config.toml $home/.config/herdr/config.toml `basename $home`
    
      BASHRC="$home/.bashrc"
      if ! grep 'source /usr/local/etc/.bashrc_append' $BASHRC > /dev/null 2>&1 ; then
        echo "Installing the sourcing of bashrc_append in $BASHRC"
        echo 'source /usr/local/etc/.bashrc_append' >> $BASHRC
        echo "" >> $BASHRC
      fi

      install_tpm $home
      install_nvim_profile $home
      install_pi_global_config $home `basename $home` $d
      trigger_bashrc_reload_for_user $home `basename $home`
    fi
  fi
done

if ! [ -d /usr/local/etc/.tmuxifier ]; then
	git clone https://github.com/jimeh/tmuxifier.git /usr/local/etc/.tmuxifier
fi

if ! [ -d /usr/local/etc/.vim/bundle/Vundle.vim ]; then
	git clone https://github.com/VundleVim/Vundle.vim.git /usr/local/etc/.vim/bundle/Vundle.vim
fi

if ! [ -f /usr/local/etc/ble.sh/out/ble.sh ]; then
  rm -fr /usr/local/etc/ble.sh
  git clone --depth 1 --recursive https://github.com/akinomyoga/ble.sh.git /usr/local/etc/ble.sh
  make -C /usr/local/etc/ble.sh
  chmod a+rw /usr/local/etc/ble.sh/out/
fi

if ! [ -f /usr/local/etc/.fzf.bash ]; then
  rm -fr /usr/local/etc/fzf
  git clone --depth 1 https://github.com/junegunn/fzf.git /usr/local/etc/fzf
  /usr/local/etc/fzf/install --all --no-update-rc
  mv $HOME/.fzf.bash /usr/local/etc/.fzf.bash
fi
