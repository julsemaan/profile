# shellcheck shell=bash
# .bashrc_append - Thin loader for jprofile bashrc fragments
#
# This file is sourced from ~/.bashrc. It loads fragments from bashrc.d/
# in deterministic order. Edit fragments in profile/bashrc.d/, not here.

# Skip everything in non-interactive shells
[[ $- != *i* ]] && return

# Discover loader directory from BASH_SOURCE
__JPROFILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source fragments in order
for __jprofile_f in "$__JPROFILE_DIR"/bashrc.d/*.bash; do
  if [ -f "$__jprofile_f" ]; then
    # shellcheck disable=SC1090
    source "$__jprofile_f"
  fi
done
unset __jprofile_f
unset __JPROFILE_DIR
