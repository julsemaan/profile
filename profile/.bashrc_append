__gwt_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

__gwt_main_worktree_path() {
  local common_dir
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1
  (cd "$common_dir/.." && pwd -P)
}

__gwt_slugify() {
  printf '%s' "$1" | tr '/[:space:]' '--' | tr -cd '[:alnum:]._-' 
}

__gwt_each() {
  git worktree list --porcelain | awk '
    /^worktree / {
      if (path != "") {
        print path "\t" branch "\t" detached "\t" locked "\t" prunable
      }
      path = substr($0, 10)
      branch = ""
      detached = 0
      locked = 0
      prunable = 0
      next
    }
    /^branch / { branch = $2; sub(/^refs\/heads\//, "", branch); next }
    /^detached$/ { detached = 1; next }
    /^locked/ { locked = 1; next }
    /^prunable/ { prunable = 1; next }
    END {
      if (path != "") {
        print path "\t" branch "\t" detached "\t" locked "\t" prunable
      }
    }
  '
}

tmux-new-coding-wt() {
  local branch="$1"
  local repo_root repo_name branch_slug wt_path

  if [ -z "$branch" ]; then
    echo "usage: tmux-new-coding-wt <branch-or-name>" >&2
    return 1
  fi

  repo_root="$(__gwt_repo_root)"
  if [ -z "$repo_root" ]; then
    echo "tmux-new-coding-wt: not inside git repo" >&2
    return 1
  fi

  repo_name="$(basename "$repo_root")"
  branch_slug="$(__gwt_slugify "$branch")"
  wt_path="$(cd "$repo_root/.." && pwd -P)/${repo_name}-${branch_slug}"

  if [ ! -e "$wt_path" ]; then
    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$repo_root" worktree add "$wt_path" "$branch" || return 1
    else
      git -C "$repo_root" worktree add -b "$branch" "$wt_path" || return 1
    fi
  fi

  tmux-new-coding "$wt_path"
}

gwt() {
  local cmd="$1"
  shift || true

  case "$cmd" in
    list)
      local current_path
      current_path="$(__gwt_repo_root)"
      if [ -z "$current_path" ]; then
        echo "gwt list: not inside git repo" >&2
        return 1
      fi

      __gwt_each | while IFS=$'\t' read -r path branch detached locked prunable; do
        local mark name flags
        mark=' '
        [ "$path" = "$current_path" ] && mark='*'
        if [ "$detached" = "1" ]; then
          name='detached'
        else
          name="$branch"
        fi
        flags=''
        [ "$locked" = "1" ] && flags="${flags:+$flags,}locked"
        [ "$prunable" = "1" ] && flags="${flags:+$flags,}prunable"
        printf '%s %-20s %s' "$mark" "$name" "$path"
        [ -n "$flags" ] && printf ' [%s]' "$flags"
        printf '\n'
      done
      ;;
    rm)
      local repo_root main_path current_path target path dirty_output selected
      repo_root="$(__gwt_repo_root)"
      if [ -z "$repo_root" ]; then
        echo "gwt rm: not inside git repo" >&2
        return 1
      fi
      main_path="$(__gwt_main_worktree_path)" || return 1
      current_path="$repo_root"
      target="$1"

      if [ -z "$target" ] && command -v fzf >/dev/null 2>&1; then
        selected="$(
          __gwt_each | while IFS=$'\t' read -r wt_path branch detached locked prunable; do
            local name
            if [ "$detached" = "1" ]; then
              name='detached'
            else
              name="$branch"
            fi
            printf '%s\t%s\n' "$name" "$wt_path"
          done | fzf --height=40% --reverse --prompt='Remove worktree> '
        )"
        [ -z "$selected" ] && return 0
        path="${selected#*$'\t'}"
      elif [ -n "$target" ] && [ -d "$target" ]; then
        path="$(cd "$target" && pwd -P)"
      else
        while IFS=$'\t' read -r wt_path branch detached locked prunable; do
          if [ "$detached" != "1" ] && [ "$branch" = "$target" ]; then
            path="$wt_path"
            break
          fi
        done < <(__gwt_each)
      fi

      if [ -z "$path" ]; then
        echo "gwt rm: worktree not found" >&2
        return 1
      fi
      if [ "$path" = "$main_path" ]; then
        echo "gwt rm: refusing main worktree" >&2
        return 1
      fi
      if [ "$path" = "$current_path" ]; then
        echo "gwt rm: refusing current worktree" >&2
        return 1
      fi
      if [ "$PWD" = "$path" ] || [[ "$PWD" == "$path/"* ]]; then
        echo "gwt rm: refusing cwd worktree" >&2
        return 1
      fi

      dirty_output="$(git -C "$path" status --porcelain 2>/dev/null)"
      if [ -n "$dirty_output" ]; then
        echo "gwt rm: refusing dirty worktree: $path" >&2
        return 1
      fi

      git worktree remove "$path"
      ;;
    prune)
      local repo_root
      repo_root="$(__gwt_repo_root)"
      if [ -z "$repo_root" ]; then
        echo "gwt prune: not inside git repo" >&2
        return 1
      fi

      git worktree prune "$@"
      ;;
    *)
      echo "usage: gwt <list|rm|prune>" >&2
      return 1
      ;;
  esac
}

