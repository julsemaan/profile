#!/bin/bash
# gwt — Git WorkTree manager
# Interactive create via fzf, list, remove, prune.

set -o nounset -o pipefail

function __die {
  echo "gwt: $*" >&2
  exit 1
}

function __slugify {
  printf '%s' "$1" | tr '/[:space:]' '--' | tr -cd '[:alnum:]._-'
}

function __repo_root {
  git rev-parse --show-toplevel 2>/dev/null
}

function __main_worktree_path {
  local common_dir
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1
  (cd "$common_dir/.." && pwd -P)
}

function __each {
  git worktree list --porcelain | awk '
    /^worktree / {
      if (path != "") {
        print path "\t" branch "\t" detached "\t" locked "\t" prunable
      }
      path = substr($0, 10)
      branch = ""
      detached = 0
      locked = 0
      prunable = 0
      next
    }
    /^branch / { branch = $2; sub(/^refs\/heads\//, "", branch); next }
    /^detached$/ { detached = 1; next }
    /^locked/ { locked = 1; next }
    /^prunable/ { prunable = 1; next }
    END {
      if (path != "") {
        print path "\t" branch "\t" detached "\t" locked "\t" prunable
      }
    }
  '
}

function __compute_wt_path {
  local repo_root="$1"
  local name="$2"
  local repo_name
  repo_name="$(basename "$repo_root")"
  echo "$(cd "$repo_root/.." && pwd -P)/${repo_name}-$(__slugify "$name")"
}

function __default_wt_name {
  local selected="${1:-}"
  case "$selected" in
    local/*) printf '%s' "${selected#local/}" ;;
    *)
      if [[ "$selected" == */* ]]; then
        printf '%s' "${selected#*/}"
      else
        printf '%s' "$selected"
      fi
      ;;
  esac
}

function __primary_branch {
  local name
  if name="$(git rev-parse --abbrev-ref refs/remotes/origin/HEAD 2>/dev/null)"; then
    name="${name#origin/}"
    printf '%s' "$name"
    return
  fi
  if git show-ref --verify --quiet refs/remotes/origin/main 2>/dev/null; then
    printf 'main'
    return
  fi
  if git show-ref --verify --quiet refs/remotes/origin/master 2>/dev/null; then
    printf 'master'
    return
  fi
  return 1
}

function __link_shared_path {
  local src="$1" dst="$2"
  [ -e "$src" ] || return 0
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    echo "  skip $dst (already exists)" >&2
    return 0
  fi
  ln -s "$src" "$dst" || __die "failed to symlink $dst -> $src"
}

function __link_shared_paths {
  local repo_root="$1" wt_path="$2"
  __link_shared_path "$repo_root/.envrc"          "$wt_path/.envrc"
  __link_shared_path "$repo_root/julsemaan-tmp"   "$wt_path/julsemaan-tmp"
}

function cmd_create {
  local repo_root
  repo_root="$(__repo_root)" || __die "not inside git repo"

  command -v fzf >/dev/null 2>&1 || __die "fzf is required for interactive create"

  local remotes=()
  while IFS= read -r remote; do
    [ -n "$remote" ] && remotes+=("$remote")
  done < <(git remote 2>/dev/null | sort)

  if [ "${#remotes[@]}" -gt 0 ]; then
    echo "Fetching all remotes..." >&2
    git fetch --all --prune || __die "git fetch failed"
  fi

  local primary_branch=""
  if [ "${#remotes[@]}" -gt 0 ]; then
    primary_branch="$(__primary_branch)" || primary_branch=""
  fi

  local branch_lines=()
  while IFS= read -r line; do
    [ -n "$line" ] && branch_lines+=("$line")
  done < <(
    {
      git for-each-ref --format='local/%(refname:short)' refs/heads 2>/dev/null
      if [ "${#remotes[@]}" -gt 0 ]; then
        for remote in "${remotes[@]}"; do
          git for-each-ref --format='%(refname:short)' "refs/remotes/${remote}" 2>/dev/null
        done
      fi
    } | grep -v '/HEAD$' | sort -u
  )

  [ "${#branch_lines[@]}" -gt 0 ] || __die "no branches found"

  local selected
  selected="$(
    printf '%s\n' "${branch_lines[@]}" | fzf --height=40% --reverse --prompt='Select branch> '
  )" || return 0

  [ -n "$selected" ] || return 0

  echo "" >&2
  local wt_name
  local default_name
  default_name="$(__default_wt_name "$selected")"
  read -r -p "Worktree name (default: $default_name): " wt_name </dev/tty
  wt_name="${wt_name:-$default_name}"

  local wt_path
  wt_path="$(__compute_wt_path "$repo_root" "$wt_name")"

  if [ -e "$wt_path" ]; then
    __die "target path already exists: $wt_path"
  fi

  case "$selected" in
    local/*)
      local branch_name="${selected#local/}"
      if [ "$branch_name" = "$primary_branch" ] && [ -n "$primary_branch" ]; then
        echo "Creating worktree with new branch '$wt_name' from $primary_branch..." >&2
        git worktree add -b "$wt_name" "$wt_path" "origin/$primary_branch" >/dev/null || __die "worktree create failed"
      elif git show-ref --verify --quiet "refs/heads/$branch_name" 2>/dev/null; then
        echo "Creating worktree on local branch '$branch_name'..." >&2
        git worktree add "$wt_path" "$branch_name" >/dev/null || __die "worktree create failed"
      else
        __die "local branch '$branch_name' does not exist"
      fi
      ;;
    */*)
      local remote="${selected%%/*}"
      local branch_name="${selected#*/}"
      local remote_ref="${remote}/${branch_name}"

      if [ -n "$primary_branch" ] && [ "$branch_name" = "$primary_branch" ] && [ "$remote" = "origin" ]; then
        echo "Creating worktree with new branch '$wt_name' from $primary_branch..." >&2
        git worktree add -b "$wt_name" "$wt_path" "origin/$primary_branch" >/dev/null || __die "worktree create failed"
      elif ! git show-ref --verify --quiet "refs/heads/$branch_name" 2>/dev/null; then
        echo "Creating tracking branch '$branch_name' from '$remote_ref'..." >&2
        git branch --track "$branch_name" "$remote_ref" || __die "failed to create tracking branch"
        git worktree add "$wt_path" "$branch_name" >/dev/null || __die "worktree create failed"
      else
        local local_commit remote_commit
        local_commit="$(git rev-parse "refs/heads/$branch_name" 2>/dev/null)"
        remote_commit="$(git rev-parse "$remote_ref" 2>/dev/null)"

        if [ "$local_commit" = "$remote_commit" ]; then
          echo "Creating worktree on existing branch '$branch_name'..." >&2
          git worktree add "$wt_path" "$branch_name" >/dev/null || __die "worktree create failed"
        else
          echo "" >&2
          echo "Local branch '$branch_name' diverges from '$remote_ref'" >&2
          local choice
          read -r -p "Reset local '$branch_name' to match remote? (y/N): " choice </dev/tty

          if [[ "$choice" =~ ^[Yy] ]]; then
            local other_wts
            other_wts="$(__each | awk -F'\t' -v b="$branch_name" '$2 == b {print $1}')"
            if [ -n "$other_wts" ]; then
              __die "cannot reset '$branch_name': checked out in other worktree(s): $other_wts"
            fi
            echo "Resetting '$branch_name' to '$remote_ref'..." >&2
            git branch -f "$branch_name" "$remote_ref" || __die "failed to reset branch"
            git worktree add "$wt_path" "$branch_name" >/dev/null || __die "worktree create failed"
          else
            if git show-ref --verify --quiet "refs/heads/$wt_name" 2>/dev/null; then
              __die "local branch '$wt_name' already exists (from worktree name)"
            fi
            echo "Creating new branch '$wt_name' from '$branch_name'..." >&2
            git worktree add -b "$wt_name" "$wt_path" "$remote_ref" >/dev/null || __die "worktree create failed"
          fi
        fi
      fi
      ;;
    *)
      local branch_name="$selected"
      if [ -n "$primary_branch" ] && [ "$branch_name" = "$primary_branch" ]; then
        echo "Creating worktree with new branch '$wt_name' from $primary_branch..." >&2
        git worktree add -b "$wt_name" "$wt_path" "origin/$primary_branch" >/dev/null || __die "worktree create failed"
      else
        echo "Creating worktree on local branch '$branch_name'..." >&2
        git worktree add "$wt_path" "$branch_name" >/dev/null || __die "worktree create failed"
      fi
      ;;
  esac

  __link_shared_paths "$repo_root" "$wt_path"

  echo "$wt_path"
}

function cmd_list {
  local current_path
  current_path="$(__repo_root)" || __die "not inside git repo"

  __each | while IFS=$'\t' read -r path branch detached locked prunable; do
    local mark name flags
    mark=' '
    [ "$path" = "$current_path" ] && mark='*'
    name="$branch"
    [ "$detached" = "1" ] && name='detached'
    flags=''
    [ "$locked" = "1" ] && flags="${flags:+$flags,}locked"
    [ "$prunable" = "1" ] && flags="${flags:+$flags,}prunable"
    printf '%s %-20s %s' "$mark" "$name" "$path"
    [ -n "$flags" ] && printf ' [%s]' "$flags"
    printf '\n'
  done
}

function cmd_rm {
  local target="${1:-}"
  local repo_root main_path current_path path

  repo_root="$(__repo_root)" || __die "not inside git repo"
  main_path="$(__main_worktree_path)" || __die "failed to detect main worktree path"
  current_path="$repo_root"

  if [ -z "$target" ] && command -v fzf >/dev/null 2>&1; then
    local selected
    selected="$(
      __each | while IFS=$'\t' read -r wt_path branch detached locked prunable; do
        local name
        if [ "$detached" = "1" ]; then
          name='detached'
        else
          name="$branch"
        fi
        printf '%s\t%s\n' "$name" "$wt_path"
      done | fzf --height=40% --reverse --prompt='Remove worktree> '
    )"
    [ -z "$selected" ] && return 0
    path="${selected#*$'\t'}"
  elif [ -z "$target" ]; then
    __die "fzf not available; specify a worktree path or branch name to remove"
  elif [ -d "$target" ]; then
    path="$(cd "$target" && pwd -P 2>/dev/null)" || __die "cannot resolve path: $target"
  else
    while IFS=$'\t' read -r wt_path branch detached locked prunable; do
      if [ "$detached" != "1" ] && [ "$branch" = "$target" ]; then
        path="$wt_path"
        break
      fi
    done < <(__each)
  fi

  [ -n "$path" ] || __die "worktree not found"

  [ "$path" != "$main_path" ] || __die "refusing to remove main worktree"
  [ "$path" != "$current_path" ] || __die "refusing to remove current worktree"
  { [ "$PWD" != "$path" ] && [[ "$PWD" != "$path/"* ]]; } || __die "refusing to remove worktree containing current directory"

  local dirty_output
  dirty_output="$(git -C "$path" status --porcelain 2>/dev/null)"
  [ -z "$dirty_output" ] || __die "refusing to remove dirty worktree: $path"

  echo "Removing worktree: $path" >&2
  git worktree remove "$path"
}

function cmd_prune {
  local repo_root
  repo_root="$(__repo_root)" || __die "not inside git repo"
  git worktree prune "$@"
}

# --- Main ---
if [ $# -eq 0 ]; then
  cmd_create
  exit $?
fi

cmd="$1"
shift

case "$cmd" in
  create)
    cmd_create
    ;;
  list)
    cmd_list
    ;;
  rm)
    cmd_rm "${@:-}"
    ;;
  prune)
    cmd_prune "$@"
    ;;
  *)
    echo "usage: gwt [create|list|rm [branch-or-path]|prune]" >&2
    echo "  (default: interactive create)" >&2
    exit 1
    ;;
esac
